# Shell entrypoints are bind-mounted into Linux containers and must retain LF.
*.sh text eol=lf

# PostgreSQL migrations and their release manifest are also bind-mounted into
# Linux containers; canonical line endings preserve their checksums.
infra/postgres/migrations/*.sql text eol=lf
infra/postgres/migrations/SHA256SUMS text eol=lf

# Rehearsal fixtures are bind-mounted into Linux containers and validated
# byte-for-byte by the edge-agent configuration tests.
infra/security/rehearsal/*.csv text eol=lf
