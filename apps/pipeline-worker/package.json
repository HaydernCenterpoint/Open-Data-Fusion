{
  "name": "@open-data-fusion/pipeline-worker",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/server.js",
  "scripts": {
    "predev": "npm --prefix ../.. run build --workspace @open-data-fusion/postgres-runtime",
    "dev": "tsx watch src/server.ts",
    "prebuild": "npm --prefix ../.. run build --workspace @open-data-fusion/postgres-runtime",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "pretest": "npm --prefix ../.. run build --workspace @open-data-fusion/postgres-runtime",
    "test": "vitest run",
    "pretypecheck": "npm --prefix ../.. run build --workspace @open-data-fusion/postgres-runtime",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@open-data-fusion/postgres-runtime": "0.1.0",
    "@opentelemetry/api-logs": "^0.220.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-logs": "^0.220.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "4.1.10"
  }
}
