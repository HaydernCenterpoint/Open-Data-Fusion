ODF_POSTGRES_URL=postgresql://odf_pipeline_worker:replace-me@127.0.0.1:5432/odf
ODF_PIPELINE_SCOPES=[{"tenantId":"11111111-1111-4111-8111-111111111111","projectId":"22222222-2222-4222-8222-222222222222"}]
ODF_PIPELINE_ACTOR_ID=pipeline-worker
# Explicit opt-in. The default is disabled so a missing executor never claims work.
ODF_PIPELINE_EXECUTOR=builtin
ODF_PIPELINE_DB_POOL_SIZE=10
ODF_PIPELINE_BATCH_SIZE=20
ODF_PIPELINE_MAX_SCOPES_PER_POLL=1
ODF_PIPELINE_CONCURRENCY=4
ODF_PIPELINE_QUALITY_RULE_PAGE_SIZE=100
ODF_PIPELINE_MAX_QUALITY_RULES=1000
ODF_PIPELINE_POLL_MS=1000
ODF_PIPELINE_RETRY_BASE_MS=250
ODF_PIPELINE_RETRY_MAX_MS=30000
ODF_PIPELINE_SHUTDOWN_GRACE_MS=30000
