# Reference only: copy settings into the repository-root .env, which is the
# single file loaded by the API. Relative paths are resolved from that root.
# Development defaults to apps/api/data/objects. Production must set an explicit path.
ODF_OBJECT_STORE_PATH=apps/api/data/objects

# Maximum raw upload size in bytes (default: 52428800 / 50 MiB).
ODF_OBJECT_STORE_MAX_BYTES=52428800

# Industrial write-back remains disabled unless explicitly configured.
ODF_WRITEBACK_ENABLED=false
ODF_WRITEBACK_ALLOWED_OPERATIONS=
ODF_WRITEBACK_MAXIMUM_RISK=low
ODF_WRITEBACK_REQUIRE_DRY_RUN=true

# One authoritative backend per process. Production requires this setting;
# SQLite is the supported single-instance/embedded profile.
ODF_DATA_PERSISTENCE=sqlite
ODF_WORKSPACE_PERSISTENCE=sqlite

# Production Canvas configuration (documentation-only; never commit a URL or
# credential). The API login must inherit odf_app only. Redis is mandatory for
# shared committed-event delivery when this mode is enabled.
# ODF_DATA_PERSISTENCE=postgres
# ODF_WORKSPACE_PERSISTENCE=postgres
# ODF_API_POSTGRES_URL=postgresql://<odf-app-login>:<password>@<postgres-host>:5432/odf
# ODF_SHARED_EVENTS_REQUIRED=true
# ODF_REDIS_URL=redis://:<password>@<redis-host>:6379/0

# Controlled tenant/project bootstrap only. This login must inherit only
# odf_tenant_provisioner, which grants migration-read plus one security-definer
# routine (no direct tenant/project/audit table access). The CLI is dry-run
# unless --apply is explicit.
# ODF_TENANT_PROVISION_POSTGRES_URL=postgresql://<tenant-provision-login>:<password>@<postgres-host>:5432/odf
