{
  "name": "@open-data-fusion/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "predev": "npm --prefix ../.. run build --workspace @open-data-fusion/platform-core",
    "dev": "tsx watch src/server.ts",
    "prebuild": "npm --prefix ../.. run build --workspace @open-data-fusion/platform-core",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "pretest": "npm --prefix ../.. run build --workspace @open-data-fusion/platform-core",
    "test": "vitest run",
    "pretest:watch": "npm --prefix ../.. run build --workspace @open-data-fusion/platform-core",
    "test:watch": "vitest",
    "pretypecheck": "npm --prefix ../.. run build --workspace @open-data-fusion/platform-core",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@open-data-fusion/contracts": "0.1.0",
    "@open-data-fusion/platform-core": "0.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "express": "^5.1.0",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.10",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.3",
    "typescript": "^7.0.2",
    "vitest": "4.1.10"
  }
}
