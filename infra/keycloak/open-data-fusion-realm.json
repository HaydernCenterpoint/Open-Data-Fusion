{
  "realm": "open-data-fusion",
  "displayName": "Open Data Fusion (local development)",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "open-data-fusion-api",
      "name": "Open Data Fusion API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false
    },
    {
      "clientId": "open-data-fusion-web",
      "name": "Open Data Fusion Web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*##http://127.0.0.1:5173/*"
      },
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "basic",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "Open Data Fusion API audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "open-data-fusion-api",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "harper.dennis",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Harper",
      "lastName": "Dennis",
      "email": "harper.dennis@example.test",
      "credentials": [
        {
          "type": "password",
          "value": "${ODF_DEMO_USER_PASSWORD}",
          "temporary": false
        }
      ]
    },
    {
      "username": "riley.chen",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Riley",
      "lastName": "Chen",
      "email": "riley.chen@example.test",
      "credentials": [
        {
          "type": "password",
          "value": "${ODF_DEMO_USER_PASSWORD}",
          "temporary": false
        }
      ]
    },
    {
      "username": "monica.reyes",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Monica",
      "lastName": "Reyes",
      "email": "monica.reyes@example.test",
      "credentials": [
        {
          "type": "password",
          "value": "${ODF_DEMO_USER_PASSWORD}",
          "temporary": false
        }
      ]
    },
    {
      "username": "samantha.lee",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Samantha",
      "lastName": "Lee",
      "email": "samantha.lee@example.test",
      "credentials": [
        {
          "type": "password",
          "value": "${ODF_DEMO_USER_PASSWORD}",
          "temporary": false
        }
      ]
    }
  ]
}
