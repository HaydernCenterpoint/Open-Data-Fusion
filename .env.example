# Local development identity. Never use this mode for an internet-facing deployment.
# ODF_AUTH_MODE=development
ODF_DEV_USER=harper.dennis

# Production OIDC resource-server example (Keycloak-compatible).
# ODF_AUTH_MODE=oidc
# ODF_OIDC_ISSUER=https://identity.example.com/realms/open-data-fusion
# ODF_OIDC_AUDIENCE=open-data-fusion-api
# ODF_OIDC_JWKS_URI=https://identity.example.com/realms/open-data-fusion/protocol/openid-connect/certs
# ODF_OIDC_USER_CLAIM=sub
# ODF_OIDC_ALGORITHMS=RS256

# Local Keycloak realm import (development only).
# KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=admin
# KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=change-this-local-admin-password
# ODF_DEMO_USER_PASSWORD=change-this-local-demo-password
# VITE_OIDC_AUTHORITY=http://localhost:8080/realms/open-data-fusion
# VITE_OIDC_CLIENT_ID=open-data-fusion-web
# VITE_OIDC_SCOPE=openid profile email
# VITE_OIDC_USER_CLAIM=preferred_username

# PORT=4310
# ODF_DATABASE_PATH=apps/api/data/open-data-fusion.db
# ODF_SEED=true
