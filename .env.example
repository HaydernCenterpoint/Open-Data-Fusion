# Local development identity. Never use this mode for an internet-facing deployment.
# ODF_AUTH_MODE=development
ODF_DEV_USER=harper.dennis

# Production OIDC resource-server example (Keycloak-compatible).
# ODF_AUTH_MODE=oidc
# ODF_OIDC_ISSUER=https://identity.example.com/realms/open-data-fusion
# ODF_OIDC_AUDIENCE=open-data-fusion-api
# ODF_OIDC_JWKS_URI=https://identity.example.com/realms/open-data-fusion/protocol/openid-connect/certs
# ODF_OIDC_USER_CLAIM=sub
# ODF_OIDC_PERMISSION_CLAIM=permissions
# ODF_OIDC_ALGORITHMS=RS256
# ODF_METRICS_TOKEN=<supply-from-secret-manager>
# ODF_OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# PostgreSQL Canvas persistence is the production default. The API URL must be
# a dedicated non-superuser login inheriting only odf_app; do not reuse the
# migrator/cutover/outbox credentials. Set SQLite only for an intentional local
# preview profile.
# ODF_WORKSPACE_PERSISTENCE=postgres
# ODF_API_POSTGRES_URL=postgresql://<odf-app-login>:<password>@<postgres-host>:5432/odf
# ODF_SHARED_EVENTS_REQUIRED=true
# ODF_REDIS_URL=redis://:<password>@<redis-host>:6379/0
# ODF_OUTBOX_POSTGRES_URL=postgresql://<odf-outbox-login>:<password>@<postgres-host>:5432/odf
# Dedicated tenant bootstrap login: migration-read plus one SECURITY DEFINER
# routine through odf_tenant_provisioner; no direct tenant/project/audit access.
# ODF_TENANT_PROVISION_POSTGRES_URL=postgresql://<tenant-provision-login>:<password>@<postgres-host>:5432/odf
# ODF_POSTGRES_ADMIN_PASSWORD=<supply-from-secret-manager>
# ODF_REDIS_PASSWORD=<supply-from-secret-manager>
# ODF_GRAFANA_ADMIN_PASSWORD=<supply-from-secret-manager>

# Industrial write-back is fail-closed. Keep disabled until a reviewed executor is injected.
# ODF_WRITEBACK_ENABLED=false
# ODF_WRITEBACK_ALLOWED_OPERATIONS=set-maintenance-note
# ODF_WRITEBACK_MAXIMUM_RISK=low
# ODF_WRITEBACK_REQUIRE_DRY_RUN=true
# ODF_WRITEBACK_APPROVALS_LOW=1
# ODF_WRITEBACK_APPROVALS_MEDIUM=1
# ODF_WRITEBACK_APPROVALS_HIGH=2

# Durable pipeline worker. Supply a dedicated least-privilege PostgreSQL login
# and an explicit JSON allowlist; the executor remains off unless enabled.
# ODF_PIPELINE_POSTGRES_URL=postgresql://odf_pipeline_worker:replace-me@odf-postgres:5432/odf
# ODF_PIPELINE_SCOPES=[{"tenantId":"11111111-1111-4111-8111-111111111111","projectId":"22222222-2222-4222-8222-222222222222"}]
# ODF_PIPELINE_ACTOR_ID=pipeline-worker
# ODF_PIPELINE_EXECUTOR=disabled

# Local Keycloak realm import (development only).
# KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=<local-admin-name>
# KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=<supply-from-secret-manager>
# ODF_DEMO_USER_PASSWORD=<supply-from-secret-manager>
# ODF_CONNECTOR_CLIENT_SECRET=<supply-from-secret-manager>
# VITE_OIDC_AUTHORITY=http://localhost:8080/realms/open-data-fusion
# VITE_OIDC_CLIENT_ID=open-data-fusion-web
# VITE_OIDC_SCOPE=openid profile email
# VITE_OIDC_USER_CLAIM=preferred_username

# PORT=4310
# ODF_DATABASE_PATH=apps/api/data/open-data-fusion.db
# ODF_RAW_LANDING_PATH=apps/api/data/raw
# ODF_OBJECT_STORE_PATH=apps/api/data/objects
# ODF_OBJECT_STORE_MAX_BYTES=52428800
# ODF_SEED=true
